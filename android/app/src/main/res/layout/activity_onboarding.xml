<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- ── Logo / Titre ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛰️"
            android:textSize="56sp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GPS Tracker"
            android:textSize="30sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenue ! Comment souhaitez-vous utiliser l'application ?"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <!-- ── Message d'erreur global ── -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#ef4444"
            android:background="#1fef4444"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:drawablePadding="8dp"/>

        <!-- ── ProgressBar ── -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:indeterminateTint="@color/primary"/>

        <!-- ══════════════════════════════════════════════════
             ÉCRAN 1 : Choix du type de compte
             ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutChoix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Carte Entreprise -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1a1f2e"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏢"
                    android:textSize="36sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entreprise / Institution"
                    android:textSize="17sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vous avez reçu un code entreprise de votre administrateur."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnChoixEntreprise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Continuer avec un code entreprise"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/background"
                    android:textStyle="bold"
                    android:minHeight="48dp"/>
            </LinearLayout>

            <!-- Carte Étudiant -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1a1f2e"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓"
                    android:textSize="36sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Étudiant"
                    android:textSize="17sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suivi de présence universitaire. Votre établissement ou votre famille suit votre assiduité."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnChoixEtudiant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Je suis étudiant"
                    android:backgroundTint="#4f46e5"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:minHeight="48dp"/>
            </LinearLayout>

            <!-- Carte Élève -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1a1f2e"
                android:padding="20dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎒"
                    android:textSize="36sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Élève (École primaire / Secondaire)"
                    android:textSize="17sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suivi scolaire activé par un parent ou un tuteur légal. Saisissez le code reçu par email."
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnChoixEleve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Je suis élève"
                    android:backgroundTint="#0891b2"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:minHeight="48dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════
             ÉCRAN 2 : Formulaire Entreprise
             ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutEntreprise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏢 Connexion Entreprise"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saisissez le code fourni par votre administrateur."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Code Entreprise -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCodeEntreprise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Code Entreprise *"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:startIconDrawable="@android:drawable/ic_menu_manage"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCodeEntreprise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nom de l'agent -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Votre nom complet *"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomAgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Téléphone de l'agent -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:hint="Votre numéro de téléphone *"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhoneAgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Bouton Valider -->
            <Button
                android:id="@+id/btnValiderCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vérifier et s'enregistrer"
                android:backgroundTint="@color/primary"
                android:textColor="@color/background"
                android:textStyle="bold"
                android:minHeight="52dp"
                android:layout_marginBottom="12dp"/>

            <!-- Retour -->
            <Button
                android:id="@+id/btnRetourEntreprise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:backgroundTint="#1e293b"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════
             ÉCRAN 3 : Formulaire Particulier
             ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutParticulier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 Créer un compte"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Renseignez vos informations pour créer votre compte personnel."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Nom -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Nom complet *"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomParticulier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Adresse email *"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmailParticulier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Mot de passe -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:hint="Mot de passe (min. 6 caractères) *"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary"
                app:passwordToggleEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMdpParticulier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Bouton Créer -->
            <Button
                android:id="@+id/btnCreerCompte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Créer mon compte"
                android:backgroundTint="@color/primary"
                android:textColor="@color/background"
                android:textStyle="bold"
                android:minHeight="52dp"
                android:layout_marginBottom="12dp"/>

            <!-- Retour -->
            <Button
                android:id="@+id/btnRetourParticulier"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:backgroundTint="#1e293b"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════
             ÉCRAN 4 : Formulaire Étudiant
             ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutEtudiant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎓 Inscription Étudiant"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saisissez le code reçu par votre établissement ou votre famille."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Code parent/établissement -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCodeEtudiant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Code parent / établissement *"
                app:boxStrokeColor="#4f46e5"
                app:hintTextColor="#4f46e5"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCodeEtudiant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nom complet -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Nom complet *"
                app:boxStrokeColor="#4f46e5"
                app:hintTextColor="#4f46e5"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomEtudiant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Numéro étudiant (optionnel) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:hint="Numéro étudiant (optionnel)"
                app:boxStrokeColor="#4f46e5"
                app:hintTextColor="#4f46e5"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNumeroEtudiant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnValiderEtudiant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="S'enregistrer comme étudiant"
                android:backgroundTint="#4f46e5"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:minHeight="52dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnRetourEtudiant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:backgroundTint="#1e293b"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════
             ÉCRAN 5 : Formulaire Élève
             ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutEleve"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎒 Inscription Élève"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saisissez le code reçu par email par votre parent ou tuteur légal."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Code parent -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCodeEleve"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Code parent *"
                app:boxStrokeColor="#0891b2"
                app:hintTextColor="#0891b2"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCodeEleve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Prénom et nom -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Prénom et nom de l'élève *"
                app:boxStrokeColor="#0891b2"
                app:hintTextColor="#0891b2"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomEleve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Classe (optionnel) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:hint="Classe (ex: 6ème A, CM2…)"
                app:boxStrokeColor="#0891b2"
                app:hintTextColor="#0891b2"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etClasseEleve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnValiderEleve"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="S'enregistrer comme élève"
                android:backgroundTint="#0891b2"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:minHeight="52dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnRetourEleve"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:backgroundTint="#1e293b"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
