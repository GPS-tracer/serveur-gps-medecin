{
  "rules": {

    "agents": {
      ".read": "auth != null",
      "$agentId": {
        ".write": true
      }
    },

    "societes": {
      "$societeId": {
        ".read": "auth != null && auth.uid == $societeId",
        ".write": "auth != null && auth.uid == $societeId",
        "agents": {
          "$agentId": {
            ".read": "auth != null && auth.uid == $societeId",
            ".write": true
          }
        }
      }
    },

    "pending": {
      "$deviceId": {
        ".read": true,
        ".write": true
      }
    },

    "companies": {
      ".read": "auth != null",
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "licences_gps": {
      ".read": false,
      ".write": false
    },

    "uninstall_alerts": {
      ".read": "auth != null",
      "$agentId": {
        ".write": true
      }
    },

    "destruction_commands": {
      "$agentId": {
        ".read": true,
        ".write": "auth != null"
      }
    }
  }
}
